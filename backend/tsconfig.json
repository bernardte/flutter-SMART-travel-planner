{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./",
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "types": ["node"],
    "skipLibCheck": true,
    "noEmitOnError": false,
    "sourceMap": true
  },
  "include": [
    // force to run server.ts in deployment as the starting point
    "server.ts",
    "**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}